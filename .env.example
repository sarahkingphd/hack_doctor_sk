# Copy this file to .env for local development.
# Do not commit .env; it may contain credentials.

# Databricks workspace:
# Workspace ID: 7474647758171864
# Cloud/region: AWS us-west-2
# Workspace UUID: 22b8448d-6839-4df9-9ec6-99001c769190
#
# This is the Databricks workspace URL from the data explorer link.
DATABRICKS_HOST=https://dbc-46f0fbb0-0c1c.cloud.databricks.com
DATABRICKS_CONFIG_PROFILE=dbx_hack_doctors

# Marketplace/catalog data:
DATABRICKS_CATALOG=databricks_virtue_foundation_dataset_dais_2026
DATABRICKS_SCHEMA=virtue_foundation_dataset
DATABRICKS_TABLE=nfhs_5_district_health_indicators

# SQL warehouse used for local downloads.
DATABRICKS_WAREHOUSE_ID=e428febecc2419c5

# Optional personal access token auth.
# Prefer OAuth via `databricks auth login` when possible.
# DATABRICKS_TOKEN=

# Databricks Apps deploy:
# Workspace path where app source is synced before deploy.
# e.g. /Workspace/Users/you@example.com/dbx-hack-doctors
DATABRICKS_APP_NAME=dbx-hack-doctors
DATABRICKS_WORKSPACE_PATH=/Workspace/Users/you@example.com/dbx-hack-doctors

# App data backend.
# APP_DATA_MODE remains as a convenience preset:
# local: checked-in/downloaded CSV source + app/state JSON/Markdown.
# unity_catalog: Databricks source + Unity Catalog result state. This is the default.
APP_DATA_MODE=unity_catalog

# Optional fine-grained backend switches.
# Default DBX mode:
APP_SOURCE_MODE=unity_catalog
APP_STATE_MODE=unity_catalog
#
# Local app over the real Databricks source catalog, while keeping scratchpad/results local:
# APP_SOURCE_MODE=unity_catalog
# APP_STATE_MODE=local
#
# Checked-in/offline click-through mode:
# APP_SOURCE_MODE=checked_in
# APP_STATE_MODE=local
APP_SOURCE_CATALOG=databricks_virtue_foundation_dataset_dais_2026
APP_SOURCE_SCHEMA=virtue_foundation_dataset
APP_SOURCE_TABLE=facilities
APP_RESULT_CATALOG=dais_readiness_desk
APP_SOURCE_ROW_LIMIT=10000
APP_STATE_LOAD_TIMEOUT_SECONDS=8
APP_STATE_FALLBACK_ON_ERROR=true

# AI Pipeline settings.
# PIPELINE_MODE=local        # default: run agents in-process via asyncio
# PIPELINE_MODE=databricks   # run agents as a Databricks multi-task Job
# DATABRICKS_PIPELINE_JOB_ID=  # set by: python scripts/setup_dbx_job.py
# DATABRICKS_LLM_MODEL=databricks-meta-llama-3-3-70b-instruct

# Optional app-level Basic Auth gate for demo links.
# If APP_BASIC_AUTH_ENABLED=true, both username and password must be set.
# Do not commit real passwords.
APP_BASIC_AUTH_ENABLED=false
APP_BASIC_AUTH_REALM=Data Readiness Desk
# APP_BASIC_AUTH_USERNAME=demo
# APP_BASIC_AUTH_PASSWORD=
